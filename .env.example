# Kopiere diese Datei nach `.env` und trage echte Werte ein.
# Für GitHub Actions: Secrets `GEMINI_API_KEY` und `NTFY_TOPIC` setzen.

# Google AI Studio / Gemini API Key
# https://aistudio.google.com/apikey
GEMINI_API_KEY=dein_gemini_api_schluessel

# ntfy-Thema (öffentlich lesbar, wenn nicht geschützt — Topic-URL geheim halten)
# https://ntfy.sh/
NTFY_TOPIC=dein_eindeutiges_topic
